              "training/custom-script",
              "training/managed",
              "training/providers",
              "training/datasets",
              "training/reward-functions",
              "training/grpo",
              "training/dpo"
            ]
          },
          {
            "group": "Deployments",
            "icon": "server",
            "pages": [
