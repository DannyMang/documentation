{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Veri Documentation",
  "description": "Veri is a platform for post-training, deploying, and evaluating language models.",
  "colors": {
    "primary": "#468F7D",
    "light": "#BDE689",
    "dark": "#200D0D"
  },
  "logo": {
    "light": "/logo/veri-mark-logo.png",
    "dark": "/logo/veri-mark-logo-light.png",
    "href": "/"
  },
  "favicon": "/favicon.ico",
  "api": {
    "openapi": "api-reference/openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "bash",
        "python",
        "javascript"
      ]
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
